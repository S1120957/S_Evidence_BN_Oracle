# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Alchemy or Infura Sepolia endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Wallet private key (no 0x prefix needed for some tools; add it if required)
PRIVATE_KEY=your_private_key_here

# Deployed contract addresses on Sepolia (from deployment/deployment_addresses_log.csv)
CPTSTORE_ADDR=0x19E2f1C1Abe30a25F7B2f52f14b6363A64C80026
CLAIMREGISTRY_ADDR=0x7d8253184Ee4685Ebf0f802FD2559d499CF56756
EVIDENCEREGISTRY_ADDR=0x37C60182079fe0a4B1185cC70f7Ee13C23E8327f
ORACLECONTROLLER_ADDR=0x53484B8e002A945D4E46c8040434bc8B3390085A

# Experiment profile: neutral or asymmetric
PROFILE_NAME=neutral
